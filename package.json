{
  "name": "astradb-datasource",
  "version": "1.0.5",
  "description": "Grafana Data Source Backend Plugin for Astra DB",
  "private": true,
  "scripts": {
    "build": "webpack -c ./.config/webpack/webpack.config.ts --env production",
    "dev": "webpack -w -c ./.config/webpack/webpack.config.ts --env development",
    "e2e:playwright": "npx playwright test",
    "e2e:playwright:ui": "npx playwright test --ui",
    "e2e:playwright:report": "npx playwright show-report",
    "lint": "eslint --cache .",
    "lint:fix": "npm run lint -- --fix && prettier --write --list-different .",
    "prettier:write": "prettier --list-different \"**/*.{js,ts,tsx,scss,md,mdx}\" --write",
    "server": "docker compose up --build",
    "sign": "npx --yes @grafana/sign-plugin@latest",
    "spellcheck": "cspell -c cspell.config.json \"**/*.{ts,tsx,js,go,md,mdx,yml,yaml,json,scss,css}\"",
    "start": "npm run dev",
    "test": "jest --watch --onlyChanged",
    "test:ci": "jest --passWithNoTests --maxWorkers 4",
    "typecheck": "tsc --noEmit",
    "e2e": "playwright test"
  },
  "author": "Grafana Labs",
  "license": "Apache-2.0",
  "dependencies": {
    "@emotion/css": "11.13.5",
    "@grafana/data": "^12.2.0",
    "@grafana/i18n": "^12.2.0",
    "@grafana/plugin-ui": "^0.13.1",
    "@grafana/runtime": "^12.2.0",
    "@grafana/schema": "^12.2.0",
    "@grafana/ui": "^12.2.0",
    "dotenv": "^16.5.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-virtualized-auto-sizer": "^1.0.26",
    "sql-formatter-plus": "^1.3.6",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@babel/core": "^7.21.4",
    "@grafana/eslint-config": "^9.0.0",
    "@grafana/plugin-e2e": "^3.4.7",
    "@grafana/tsconfig": "^2.0.0",
    "@playwright/test": "1.58.2",
    "@stylistic/eslint-plugin-ts": "^4.0.0",
    "@swc/core": "^1.15.18",
    "@swc/helpers": "^0.5.19",
    "@swc/jest": "^0.2.37",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.20",
    "@types/node": "^20.19.37",
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.3.0",
    "@typescript-eslint/parser": "^8.3.0",
    "copy-webpack-plugin": "^14.0.0",
    "cspell": "^9.7.0",
    "css-loader": "^7.1.2",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-jsdoc": "^62.7.1",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-webpack-plugin": "^5.0.2",
    "fork-ts-checker-webpack-plugin": "^9.1.0",
    "glob": "^13.0.0",
    "identity-obj-proxy": "3.0.0",
    "imports-loader": "^5.0.0",
    "jest": "^30.0.0",
    "jest-environment-jsdom": "^30.0.0",
    "prettier": "^3.8.1",
    "replace-in-file-webpack-plugin": "^1.0.6",
    "sass": "1.98.0",
    "sass-loader": "16.0.7",
    "semver": "^7.7.3",
    "style-loader": "4.0.0",
    "swc-loader": "^0.2.6",
    "terser-webpack-plugin": "^5.3.14",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "5.9.3",
    "webpack": "^5.105.0",
    "webpack-cli": "^6.0.1",
    "webpack-livereload-plugin": "^3.0.2",
    "webpack-subresource-integrity": "^5.2.0-rc.1",
    "webpack-virtual-modules": "^0.6.2"
  },
  "engines": {
    "node": ">=22"
  }
}
